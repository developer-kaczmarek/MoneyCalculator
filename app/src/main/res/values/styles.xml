<resources>

    <!-- Base application theme -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:editTextStyle">@style/EditTextTheme</item>
        <item name="android:windowBackground">@color/gray_f3f</item>
    </style>

    <!-- Splash theme -->
    <style name="SplashTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="android:windowBackground">@drawable/list_splash_background</item>
    </style>

    <!-- Keyboards -->
    <style name="KeyboardTextTheme" parent="AppTheme">
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:fontFamily">@font/gotham_pro_medium</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="KeyboardImageTheme" parent="AppTheme">
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:scaleType">centerInside</item>
    </style>

    <!-- Edit Text Theme -->
    <style name="EditTextTheme" parent="@android:style/Widget.Holo.Light.EditText">
        <item name="android:textCursorDrawable">@drawable/shape_rect_cursor</item>
        <item name="android:windowSoftInputMode">stateAlwaysHidden</item>
    </style>

    <!--Toolbar-->
    <style name="ThemeToolbar" parent="ThemeOverlay.AppCompat.Dark.ActionBar">
        <item name="android:background">@color/colorPrimary</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="colorControlNormal">@color/white</item>
        <item name="colorControlHighlight">@color/black_333</item>
    </style>

    <style name="ToolBarTitleTextAppearance" parent="Base.TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:fontFamily">@font/gotham_pro_medium</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Settings Theme -->
    <style name="SettingsTitleTheme" parent="AppTheme">
        <item name="android:fontFamily">@font/gotham_pro_medium</item>
        <item name="android:textSize">16sp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:background">@color/white</item>
        <item name="android:textColor">#A4A4A4</item>
    </style>

    <style name="SettingsDescriptionTheme" parent="AppTheme">
        <item name="android:fontFamily">@font/gotham_pro</item>
        <item name="android:textSize">14sp</item>
        <item name="android:padding">16dp</item>
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="android:background">?attr/selectableItemBackground</item>
    </style>

    <style name="RadioButtonTheme" parent="AppTheme">
        <item name="android:fontFamily">@font/gotham_pro</item>
        <item name="android:textSize">14sp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:textColor">@color/colorPrimary</item>
    </style>

</resources>
